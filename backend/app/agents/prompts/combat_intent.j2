- {{ npc.name }} (ID: {{ npc.npc_id | default(npc.id) }}){% if npc.occupation %}, {{ npc.occupation }}{% endif %}{% if npc.sentiment is defined %} — sentiment: {{ npc.sentiment }}{% endif %}
{% endfor %}
